# 🔹 Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc.*

# 🔹 Virtual environment (VERY IMPORTANT)
venv/
.env/
.venv/

# 🔹 Environment variables
.env

# 🔹 Data files (large datasets)
data/
processed/

# 🔹 Model files (can be large)
models/
*.pkl
*.h5

# 🔹 Jupyter (if ever used)
.ipynb_checkpoints/

# 🔹 Logs
*.log

# 🔹 OS files
.DS_Store
Thumbs.db

# 🔹 VS Code settings (optional)
.vscode/

# 🔹 Build / cache
build/
dist/
*.egg-info/

# 🔹 Temporary files
*.tmp
*.temp

# 🔹 Node (if you add frontend later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 🔹 Coverage / testing
.coverage
htmlcov/